diff --git a/CMakeLists.txt b/CMakeLists.txt
index 4641d6a..e604673 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -74,7 +74,9 @@ project(${HOLOSCAN_PACKAGE_NAME}
     DESCRIPTION "Holoscan SDK"
     LANGUAGES C CXX
 )
-include(SetupCUDA) # CUDA Language enabled there after additional setup
+
+ # Enable CUDA language (needed for CMAKE_CUDA_COMPILER)
