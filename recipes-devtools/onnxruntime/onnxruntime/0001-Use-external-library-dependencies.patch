From b0a93a93c9b23b3d92cd1f8a57c48e0d985ec0a3 Mon Sep 17 00:00:00 2001
From: Ilies CHERGUI <ichergui@nvidia.com>
Date: Fri, 8 May 2026 15:48:00 -0700
Subject: [PATCH] Use external library dependencies

This changes the dependencies on the following libraries so
that they are provided at build time instead of being
fetched, built, and installed by CMake:

 - Boost (mp11)
 - Microsoft.GSL
 - ONNX
 - cutlass
 - flatbuffers
 - Eigen3
 - pybind11

Also drops the per-target ONNX compile-definitions block, which
only applies when building ONNX from source.

Upstream-Status: Inappropriate [OE-specific]
Signed-off-by: Ilies CHERGUI <ichergui@nvidia.com>
---
 cmake/external/cutlass.cmake                  |  3 +-
 cmake/external/eigen.cmake                    |  1 +
 .../external/onnxruntime_external_deps.cmake  | 33 ++++++++-----------
 cmake/external/pybind11.cmake                 |  2 +-
 cmake/onnxruntime_python.cmake                |  9 -----
 cmake/onnxruntime_webassembly.cmake           |  1 +
 onnxruntime/core/flatbuffers/schema/ort.fbs.h |  7 ----
 .../schema/ort_training_checkpoint.fbs.h      |  7 ----
 .../transpose_optimization/optimizer_api.h    |  1 +
 .../DirectMLHelpers/DmlGraphDesc_generated.h  |  7 ----
 .../OperatorFieldTypes_generated.h            |  7 ----
 .../lora/adapter_format/adapter_schema.fbs.h  |  7 ----
 .../flatbuffers/flatbuffers_utils_test.fbs.h  |  7 ----
 13 files changed, 19 insertions(+), 73 deletions(-)

diff --git a/cmake/external/cutlass.cmake b/cmake/external/cutlass.cmake
index df554269df..010ab48c82 100644
--- a/cmake/external/cutlass.cmake
+++ b/cmake/external/cutlass.cmake
@@ -4,7 +4,8 @@ onnxruntime_fetchcontent_declare(
   URL ${DEP_URL_cutlass}
   URL_HASH SHA1=${DEP_SHA1_cutlass}
   EXCLUDE_FROM_ALL
-PATCH_COMMAND ${Patch_EXECUTABLE} --ignore-whitespace -p1 < ${PROJECT_SOURCE_DIR}/patches/cutlass/cutlass_4.2.1.patch
+  PATCH_COMMAND ${Patch_EXECUTABLE} --ignore-whitespace -p1 < ${PROJECT_SOURCE_DIR}/patches/cutlass/cutlass_4.2.1.patch
+  FIND_PACKAGE_ARGS 4.2.1 NAMES NvidiaCutlass
 )
 
 FetchContent_GetProperties(cutlass)
diff --git a/cmake/external/eigen.cmake b/cmake/external/eigen.cmake
index 2f55860f34..e4e14d8fac 100644
--- a/cmake/external/eigen.cmake
+++ b/cmake/external/eigen.cmake
@@ -14,5 +14,6 @@ onnxruntime_fetchcontent_declare(
     PATCH_COMMAND ${Patch_EXECUTABLE} --binary --ignore-whitespace -p1 < ${PATCH_EIGEN_S390X} &&
                   ${Patch_EXECUTABLE} --binary --ignore-whitespace -p1 < ${PATCH_EIGEN_S390X_WERROR}
     EXCLUDE_FROM_ALL
+    FIND_PACKAGE_ARGS NAMES Eigen3
 )
 onnxruntime_fetchcontent_makeavailable(Eigen3)
diff --git a/cmake/external/onnxruntime_external_deps.cmake b/cmake/external/onnxruntime_external_deps.cmake
index 9feb7772d1..98073bf1b1 100644
--- a/cmake/external/onnxruntime_external_deps.cmake
+++ b/cmake/external/onnxruntime_external_deps.cmake
@@ -284,17 +284,13 @@ if(NOT TARGET Boost::mp11)
      message(STATUS "Aliasing Boost::headers to Boost::mp11")
      add_library(Boost::mp11 ALIAS Boost::headers)
   else()
-    onnxruntime_fetchcontent_declare(
-     mp11
-     URL ${DEP_URL_mp11}
-     EXCLUDE_FROM_ALL
-     FIND_PACKAGE_ARGS NAMES Boost
-    )
-    FetchContent_Populate(mp11)
-    if(NOT TARGET Boost::mp11)
-      add_library(Boost::mp11 IMPORTED INTERFACE)
-      target_include_directories(Boost::mp11 INTERFACE $<BUILD_INTERFACE:${mp11_SOURCE_DIR}/include>)
-    endif()
+    # OE override: use the externally provided Boost headers package and
+    # alias Boost::headers to Boost::mp11. Upstream's FetchContent_Populate(mp11)
+    # does not honor FIND_PACKAGE_ARGS (only MakeAvailable does). OE's Boost
+    # ships boost_headers-config.cmake (providing Boost::headers, which contains
+    # the mp11 headers) but no per-module boost_mp11Config.cmake.
+    find_package(boost_headers 1.90.0 CONFIG REQUIRED)
+    add_library(Boost::mp11 ALIAS Boost::headers)
   endif()
 endif()
 
@@ -398,7 +394,7 @@ if(onnxruntime_USE_CUDA)
     URL_HASH SHA1=${DEP_SHA1_microsoft_gsl}
     PATCH_COMMAND ${Patch_EXECUTABLE} --binary --ignore-whitespace -p1 < ${PROJECT_SOURCE_DIR}/patches/gsl/1064.patch
     EXCLUDE_FROM_ALL
-    FIND_PACKAGE_ARGS 4.0 NAMES Microsoft.GSL
+    FIND_PACKAGE_ARGS 4.2.1 NAMES Microsoft.GSL
   )
 else()
   onnxruntime_fetchcontent_declare(
@@ -406,7 +402,7 @@ else()
     URL ${DEP_URL_microsoft_gsl}
     URL_HASH SHA1=${DEP_SHA1_microsoft_gsl}
     EXCLUDE_FROM_ALL
-    FIND_PACKAGE_ARGS 4.0 NAMES Microsoft.GSL
+    FIND_PACKAGE_ARGS 4.2.1 NAMES Microsoft.GSL
   )
 endif()
 set(GSL_TARGET "Microsoft.GSL::GSL")
@@ -462,7 +458,7 @@ onnxruntime_fetchcontent_declare(
     URL_HASH SHA1=${DEP_SHA1_flatbuffers}
     PATCH_COMMAND ${ONNXRUNTIME_FLATBUFFERS_PATCH_COMMAND}
     EXCLUDE_FROM_ALL
-    FIND_PACKAGE_ARGS 23.5.9 NAMES Flatbuffers flatbuffers
+    FIND_PACKAGE_ARGS 25.12.19 NAMES Flatbuffers flatbuffers
 )
 
 onnxruntime_fetchcontent_makeavailable(flatbuffers)
@@ -527,7 +523,7 @@ onnxruntime_fetchcontent_declare(
   URL_HASH SHA1=${DEP_SHA1_onnx}
   PATCH_COMMAND ${ONNXRUNTIME_ONNX_PATCH_COMMAND}
   EXCLUDE_FROM_ALL
-  FIND_PACKAGE_ARGS NAMES ONNX onnx
+  FIND_PACKAGE_ARGS 1.20.1 NAMES ONNX
 )
 
 onnxruntime_fetchcontent_makeavailable(onnx)
@@ -587,11 +583,8 @@ set(onnxruntime_EXTERNAL_LIBRARIES ${onnxruntime_EXTERNAL_LIBRARIES_XNNPACK} ${W
 # The other libs do not have the problem. All the sources are already there. We can compile them in any order.
 set(onnxruntime_EXTERNAL_DEPENDENCIES onnx_proto flatbuffers::flatbuffers)
 
-if(NOT (onnx_FOUND OR ONNX_FOUND)) # building ONNX from source
-  target_compile_definitions(onnx PUBLIC $<TARGET_PROPERTY:onnx_proto,INTERFACE_COMPILE_DEFINITIONS> PRIVATE "__ONNX_DISABLE_STATIC_REGISTRATION")
-  if (NOT onnxruntime_USE_FULL_PROTOBUF)
-    target_compile_definitions(onnx PUBLIC "__ONNX_NO_DOC_STRINGS")
-  endif()
+if (onnxruntime_RUN_ONNX_TESTS)
+  add_definitions(-DORT_RUN_EXTERNAL_ONNX_TESTS)
 endif()
 
 if(onnxruntime_ENABLE_DLPACK)
diff --git a/cmake/external/pybind11.cmake b/cmake/external/pybind11.cmake
index 79280c97a8..f47ad4d532 100644
--- a/cmake/external/pybind11.cmake
