From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Ilies CHERGUI <ichergui@nvidia.com>
Date: Wed, 15 Jul 2026 00:00:00 -0700
Subject: [PATCH 7/7] Route Python package data via SKBUILD_PLATLIB_DIR

PyTorch 2.13 installs the Python package data (type stubs, _inductor
templates, benchmark sources, version.py, ...) from CMake using
destinations relative to CMAKE_INSTALL_PREFIX ("." == the wheel's torch/
directory). That assumes CMAKE_INSTALL_PREFIX points at <site-packages>/torch,
as scikit-build-core arranges.

When CMake is driven directly with a system prefix (e.g. OpenEmbedded with
CMAKE_INSTALL_PREFIX=/usr, where the C++ runtime and headers belong), these
"." destinations scatter the torch package data across /usr/* instead of the
Python package. Honor SKBUILD_PLATLIB_DIR (already used by FileMirroring.cmake
for the same purpose) so the data lands in <site-packages>/torch regardless of
the install prefix. Under scikit-build-core SKBUILD_PLATLIB_DIR is the wheel
site-packages root and CMAKE_INSTALL_PREFIX is <platlib>/torch, so the two
forms are equivalent and native builds are unaffected.

Upstream-Status: Pending

Signed-off-by: Ilies CHERGUI <ichergui@nvidia.com>
---
diff --git a/cmake/PackageData.cmake b/cmake/PackageData.cmake
index 53e39b7..88043e2 100644
--- a/cmake/PackageData.cmake
+++ b/cmake/PackageData.cmake
@@ -14,11 +14,25 @@ if(NOT DEFINED TORCH_SRC_DIR)
   set(TORCH_SRC_DIR "${PROJECT_SOURCE_DIR}/torch")
 endif()
 
+# Route package data into the Python package tree. Under scikit-build-core
+# SKBUILD_PLATLIB_DIR is the site-packages root and CMAKE_INSTALL_PREFIX is
+# <platlib>/torch, so "." and "${SKBUILD_PLATLIB_DIR}/torch" are equivalent.
+# When CMake is invoked directly with a system prefix (e.g. OpenEmbedded with
+# prefix=/usr) they differ and using the bare prefix scatters torch package
+# data across the prefix; honor SKBUILD_PLATLIB_DIR so it lands in
+# <site-packages>/torch. FileMirroring.cmake (included earlier) defines the
+# fallback to ${PROJECT_SOURCE_DIR}, matching the historic "." behavior.
+if(DEFINED SKBUILD_PLATLIB_DIR)
+  set(_torch_pkg_dest "${SKBUILD_PLATLIB_DIR}/torch")
+else()
+  set(_torch_pkg_dest ".")
+endif()
+
 # --- torch package data ---
 
 # Type stubs
 install(DIRECTORY "${TORCH_SRC_DIR}/"
-  DESTINATION "."
+  DESTINATION "${_torch_pkg_dest}"
   FILES_MATCHING
   PATTERN "*.pyi"
   PATTERN "py.typed"
@@ -31,7 +45,7 @@ install(DIRECTORY "${TORCH_SRC_DIR}/"
 # (*.h files are copied from third_party/ by FileMirroring.cmake; the pattern
 # here picks them up if already present.)
 install(DIRECTORY "${TORCH_SRC_DIR}/utils/benchmark/utils/"
-  DESTINATION "utils/benchmark/utils"
+  DESTINATION "${_torch_pkg_dest}/utils/benchmark/utils"
   FILES_MATCHING PATTERN "*.cpp" PATTERN "*.h"
 )
 
@@ -39,37 +53,37 @@ install(DIRECTORY "${TORCH_SRC_DIR}/utils/benchmark/utils/"
 install(FILES
   "${TORCH_SRC_DIR}/utils/model_dump/skeleton.html"
   "${TORCH_SRC_DIR}/utils/model_dump/code.js"
-  DESTINATION "utils/model_dump"
+  DESTINATION "${_torch_pkg_dest}/utils/model_dump"
   OPTIONAL
 )
 install(DIRECTORY "${TORCH_SRC_DIR}/utils/model_dump/"
-  DESTINATION "utils/model_dump"
+  DESTINATION "${_torch_pkg_dest}/utils/model_dump"
   FILES_MATCHING PATTERN "*.mjs"
 )
 
 # Inductor data files
 install(FILES "${TORCH_SRC_DIR}/_inductor/script.ld"
-  DESTINATION "_inductor"
+  DESTINATION "${_torch_pkg_dest}/_inductor"
   OPTIONAL
 )
 install(DIRECTORY "${TORCH_SRC_DIR}/_inductor/codegen/"
-  DESTINATION "_inductor/codegen"
+  DESTINATION "${_torch_pkg_dest}/_inductor/codegen"
   FILES_MATCHING
   PATTERN "*.h"
   PATTERN "*.cpp"
 )
 install(DIRECTORY "${TORCH_SRC_DIR}/_inductor/kernel/flex/templates/"
-  DESTINATION "_inductor/kernel/flex/templates"
+  DESTINATION "${_torch_pkg_dest}/_inductor/kernel/flex/templates"
   FILES_MATCHING PATTERN "*.jinja"
 )
 install(DIRECTORY "${TORCH_SRC_DIR}/_inductor/kernel/templates/"
-  DESTINATION "_inductor/kernel/templates"
+  DESTINATION "${_torch_pkg_dest}/_inductor/kernel/templates"
   FILES_MATCHING PATTERN "*.jinja"
 )
 
 # Export serde data
 install(DIRECTORY "${TORCH_SRC_DIR}/_export/serde/"
-  DESTINATION "_export/serde"
+  DESTINATION "${_torch_pkg_dest}/_export/serde"
   FILES_MATCHING
   PATTERN "*.yaml"
   PATTERN "*.thrift"
@@ -77,18 +91,18 @@ install(DIRECTORY "${TORCH_SRC_DIR}/_export/serde/"
 
 # AOTI runtime header
 install(FILES "${TORCH_SRC_DIR}/csrc/inductor/aoti_runtime/model.h"
-  DESTINATION "csrc/inductor/aoti_runtime"
+  DESTINATION "${_torch_pkg_dest}/csrc/inductor/aoti_runtime"
   OPTIONAL
 )
 
 # Generated testing Python module (gitignored so not picked up by scikit-build-core
 # package scanning; install explicitly so it ends up in the wheel).
 install(FILES "${TORCH_SRC_DIR}/testing/_internal/generated/annotated_fn_args.py"
-  DESTINATION "testing/_internal/generated"
+  DESTINATION "${_torch_pkg_dest}/testing/_internal/generated"
 )
 
 # Dynamo data
 install(FILES "${TORCH_SRC_DIR}/_dynamo/graph_break_registry.json"
-  DESTINATION "_dynamo"
+  DESTINATION "${_torch_pkg_dest}/_dynamo"
   OPTIONAL
 )
diff --git a/torch/CMakeLists.txt b/torch/CMakeLists.txt
index 23aa88d..37ff29f 100644
--- a/torch/CMakeLists.txt
+++ b/torch/CMakeLists.txt
@@ -497,7 +497,11 @@ add_custom_target(
 add_dependencies(torch_python gen_torch_version)
 # version.py is gitignored (generated), so scikit-build-core won't include it
 # via Python package collection. Install it explicitly via cmake instead.
-install(FILES "${TORCH_SRC_DIR}/version.py" DESTINATION ".")
+if(DEFINED SKBUILD_PLATLIB_DIR)
+  install(FILES "${TORCH_SRC_DIR}/version.py" DESTINATION "${SKBUILD_PLATLIB_DIR}/torch")
+else()
+  install(FILES "${TORCH_SRC_DIR}/version.py" DESTINATION ".")
+endif()
 
 # Skip building this library under MacOS, since it is currently failing to build on Mac
 # Github issue #61930
-- 
