From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Peter Bergin <peter@berginkonsult.se>
Date: Mon, 17 Feb 2026 00:00:00 +0000
Subject: [PATCH] Fix CUDA build rules for cross compilation

Remove CMAKE_CUDA_FLAGS appends that occur before enable_language(CUDA).
These prevent CMake from initializing CMAKE_CUDA_FLAGS from the CUDAFLAGS
environment variable, which contains the critical -Xcompiler --sysroot=...
flags needed by the gcc-for-nvcc host compiler to find system headers.

The removed flags are instead passed via CUDA_NVCC_EXTRA_FLAGS in the
recipe, which flow through the CUDAFLAGS environment variable set by
OE's cuda.bbclass.

Also add CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES to c10_cuda, caffe2_nvrtc,
torch_cuda_linalg, ATen_CUDA_INCLUDE and torch_python so that CUDA headers from the target
sysroot (e.g. nvml.h, nvrtc.h, cusparse.h) are found during cross
compilation. In a cross build, find_package(CUDAToolkit) only sees the
native sysroot, so these headers are not on the default include path for
CXX/CUDA targets.

Upstream-Status: Inappropriate [OE-specific]

AI-Generated: Uses Claude

Signed-off-by: Peter Bergin <peter@berginkonsult.se>
Signed-off-by: Peter Bergin <peter.bergin@1x.tech>
---
 CMakeLists.txt               | 4 ----
 aten/src/ATen/CMakeLists.txt | 2 ++
 c10/cuda/CMakeLists.txt      | 3 +++
 caffe2/CMakeLists.txt        | 2 ++
 torch/CMakeLists.txt         | 2 ++
 5 files changed, 9 insertions(+), 4 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -67,10 +67,8 @@ endif()

 # This define is needed to preserve behavior given anticpated changes to
 # cccl/thrust
 # https://nvidia.github.io/cccl/libcudacxx/standard_api/numerics_library/complex.html
-string(APPEND CMAKE_CUDA_FLAGS
-       " -DLIBCUDACXX_ENABLE_SIMPLIFIED_COMPLEX_OPERATIONS")

 if(LINUX)
   set(CXX_STANDARD_REQUIRED ON)
 endif()
@@ -674,8 +672,6 @@ if(MSVC)
   string(APPEND CMAKE_CUDA_FLAGS " -Xcompiler /FS")
 endif(MSVC)

-string(APPEND CMAKE_CUDA_FLAGS " -Xfatbin -compress-all")
-
 # Set linker max-page-size to 64KiB on AArch64 Linux
 if(LINUX AND CPU_AARCH64)
   add_link_options_if_supported("-z,max-page-size=0x10000")
diff --git a/aten/src/ATen/CMakeLists.txt b/aten/src/ATen/CMakeLists.txt
--- a/aten/src/ATen/CMakeLists.txt
+++ b/aten/src/ATen/CMakeLists.txt
@@ -449,4 +449,6 @@ if(USE_CUDA)
   list(APPEND ATen_CUDA_INCLUDE ${CMAKE_CURRENT_SOURCE_DIR}/cuda)
+  # Add target-sysroot CUDA headers for cross compilation
+  list(APPEND ATen_CUDA_INCLUDE ${CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES})
   # Next two lines are needed because TunableOp uses third-party/fmt
   list(APPEND ATen_CUDA_INCLUDE $<TARGET_PROPERTY:fmt::fmt-header-only,INTERFACE_INCLUDE_DIRECTORIES>)
   list(APPEND ATen_CUDA_DEPENDENCY_LIBS fmt::fmt-header-only)
diff --git a/c10/cuda/CMakeLists.txt b/c10/cuda/CMakeLists.txt
--- a/c10/cuda/CMakeLists.txt
+++ b/c10/cuda/CMakeLists.txt
@@ -79,6 +79,9 @@ else()
       $<BUILD_INTERFACE:${CMAKE_BINARY_DIR}>
       $<INSTALL_INTERFACE:include>)

+  target_include_directories(
+      c10_cuda PRIVATE ${CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES})
+
 # ---[ Installation
 # Note: for now, we will put all export path into one single Caffe2Targets group
 # to deal with the cmake deployment need. Inside the Caffe2Targets set, the
diff --git a/caffe2/CMakeLists.txt b/caffe2/CMakeLists.txt
--- a/caffe2/CMakeLists.txt
+++ b/caffe2/CMakeLists.txt
@@ -577,3 +577,4 @@ if(USE_CUDA)
   target_link_libraries(caffe2_nvrtc PRIVATE caffe2::nvrtc ${DELAY_LOAD_FLAGS})
+  target_include_directories(caffe2_nvrtc PRIVATE ${CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES})
   install(TARGETS caffe2_nvrtc DESTINATION "${TORCH_INSTALL_LIB_DIR}")
   if(USE_NCCL)
@@ -1089,6 +1090,7 @@ if(USE_CUDA)
   if(BUILD_LAZY_CUDA_LINALG)
     add_library(torch_cuda_linalg ${ATen_CUDA_LINALG_SRCS})
     target_compile_definitions(torch_cuda_linalg PRIVATE USE_CUDA BUILD_LAZY_CUDA_LINALG)
+    target_include_directories(torch_cuda_linalg PRIVATE ${CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES})
     # Library order is important during static linking
     # `torch::magma` should be mentioned before other CUDA
     # to transitively include all symbols present in torch_cuda/torch_cpu
diff --git a/torch/CMakeLists.txt b/torch/CMakeLists.txt
--- a/torch/CMakeLists.txt
+++ b/torch/CMakeLists.txt
@@ -137,4 +137,6 @@ if(USE_CUDA)
     list(APPEND TORCH_PYTHON_COMPILE_DEFINITIONS USE_CUDA)
+    # Add target-sysroot CUDA headers for cross compilation
+    list(APPEND TORCH_PYTHON_INCLUDE_DIRECTORIES ${CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES})
     if(USE_CUDNN)
         list(APPEND TORCH_PYTHON_LINK_LIBRARIES torch::cudnn)
         list(APPEND TORCH_PYTHON_COMPILE_DEFINITIONS USE_CUDNN)
